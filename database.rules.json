{
  "rules": {

    // ============================================================
    //  🔐 SANAYEI ASWAN — Firebase Realtime Database Security Rules
    //  المشروع: صنايعي أسوان
    //  آخر تحديث: 2025
    // ============================================================

    // ─── مساعد: هل المستخدم أدمن فرعي؟ ───
    // (الأدمن الأصلي يُكشف بالإيميل من داخل الكود، مش هنا)

    // ────────────────────────────────────────────────
    //  1. PROFILES — بروفايل كل المستخدمين
    // ────────────────────────────────────────────────
    "profiles": {
      ".read": "auth != null",                   // أي مستخدم مسجّل يقدر يقرأ (عشان قائمة الصنايعية)
      "$uid": {
        ".read":  "auth != null",
        ".write": "auth != null && auth.uid === $uid"  // كل واحد يعدّل بروفايله بس
      }
    },

    // ────────────────────────────────────────────────
    //  2. CRAFTSMEN — بيانات الصنايعي العامة (التقييمات، التوفر)
    // ────────────────────────────────────────────────
    "craftsmen": {
      ".read": true,                             // الزوار يقدروا يشوفوا الصنايعية في الصفحة الرئيسية
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"  // الصنايعي يعدّل بياناته بس
      }
    },

    // ────────────────────────────────────────────────
    //  3. SERVICE REQUESTS — الطلبات (صنايعي → عميل)
    // ────────────────────────────────────────────────
    "service_requests": {
      ".read":  "auth != null",                  // أي مستخدم مسجّل يقدر يقرأ (الصنايعي يشوف الطلبات)
      "$orderNum": {
        ".write": "auth != null"                 // المستخدم المسجّل يقدر يكتب/يحدّث (العميل ينشئ، الصنايعي يقبل)
      }
    },

    // ────────────────────────────────────────────────
    //  4. CLIENT REQUESTS — سوق العروض (عميل → صنايعي)
    // ────────────────────────────────────────────────
    "client_requests": {
      ".read":  "auth != null",                  // الصنايعي يشوف العروض في السوق
      "$reqId": {
        ".write": "auth != null"                 // المستخدم المسجّل يكتب/يحدّث (العميل ينشئ، الصنايعي يبعت عرض)
      }
    },

    // ────────────────────────────────────────────────
    //  5. CHATS — الشات بين المستخدمين
    // ────────────────────────────────────────────────
    "chats": {
      "$chatId": {
        // الشات بيتكوّن من uid_uid مرتبين أبجدياً
        ".read":  "auth != null && ($chatId.contains(auth.uid))",
        ".write": "auth != null && ($chatId.contains(auth.uid))"
      }
    },

    // ────────────────────────────────────────────────
    //  6. NOTIFICATIONS — إشعارات المستخدم
    // ────────────────────────────────────────────────
    "notifications": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",  // بس صاحب الإشعار
        ".write": "auth != null"                        // أي مستخدم مسجّل يقدر يبعت إشعار لغيره
      }
    },

    // ────────────────────────────────────────────────
    //  7. WALLETS — محفظة الصنايعي
    // ────────────────────────────────────────────────
    "wallets": {
      ".read": "auth != null",                   // الأدمن يقدر يقرأ (بيستخدمه في لوحة التحكم)
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",  // الصنايعي يشوف محفظته
        ".write": "auth != null"                        // الأدمن والنظام يقدروا يحدّثوا الأرصدة
      }
    },

    // ────────────────────────────────────────────────
    //  8. WALLET TRANSACTIONS — سجل المعاملات
    // ────────────────────────────────────────────────
    "wallet_transactions": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",  // بس صاحب الحساب
        ".write": "auth != null"                        // النظام والأدمن يكتبوا المعاملات
      }
    },

    // ────────────────────────────────────────────────
    //  9. WALLET PENDING — طلبات الشحن المعلقة (كاشير)
    // ────────────────────────────────────────────────
    "wallet_pending": {
      ".read":  "auth != null",                  // الأدمن يشوف الطلبات المعلقة
      ".write": "auth != null"                   // المستخدم يسجّل طلب الشحن
    },

    // ────────────────────────────────────────────────
    //  10. PORTFOLIO — معرض أعمال الصنايعي
    // ────────────────────────────────────────────────
    "portfolio": {
      "$uid": {
        ".read":  true,                               // الزوار يشوفوا معرض الأعمال
        ".write": "auth != null && auth.uid === $uid" // بس الصنايعي يعدّل معرضه
      }
    },

    // ────────────────────────────────────────────────
    //  11. ADMIN PERMISSIONS — صلاحيات الأدمن الفرعي
    // ────────────────────────────────────────────────
    "admin_permissions": {
      ".read": "auth != null",                   // المستخدمين يتحققوا من صلاحياتهم
      "$uid": {
        ".write": "auth != null"                 // الأدمن الأصلي بس يكتب (تتحقق من الكود)
      }
    },

    // ────────────────────────────────────────────────
    //  12. BLOCKED USERS — المستخدمين المحظورين
    // ────────────────────────────────────────────────
    "blocked_users": {
      ".read": "auth != null",                   // لازم يتحقق منه عند تسجيل الدخول
      "$uid": {
        ".write": "auth != null"                 // الأدمن بس يحظر/يرفع الحظر (من الكود)
      }
    },

    // ────────────────────────────────────────────────
    //  13. DELETED USERS — الحسابات المحذوفة
    // ────────────────────────────────────────────────
    "deleted_users": {
      ".read": "auth != null",                   // لازم يتحقق منه عند تسجيل الدخول
      "$uid": {
        ".write": "auth != null"                 // الأدمن بس يحذف حسابات (من الكود)
      }
    },

    // ────────────────────────────────────────────────
    //  14. CONTACT MESSAGES — رسائل التواصل مع الأدمن
    // ────────────────────────────────────────────────
    "contact_messages": {
      ".read":  "auth != null",                  // الأدمن يقرأ الرسائل
      ".write": "auth != null"                   // أي مستخدم مسجّل يبعت رسالة
    },

    // ────────────────────────────────────────────────
    //  15. CUSTOM SERVICES — الخدمات المخصصة (الأدمن يضيفها)
    // ────────────────────────────────────────────────
    "custom_services": {
      ".read":  true,                            // الزوار يشوفوا قائمة الخدمات
      ".write": "auth != null"                   // الأدمن بس يضيف/يحذف (من الكود)
    },

    // ────────────────────────────────────────────────
    //  16. PROMOS — العروض والخصومات على العمولة
    // ────────────────────────────────────────────────
    "promos": {
      ".read":  "auth != null",                  // الصنايعي يشوف العروض الحالية
      ".write": "auth != null"                   // الأدمن بس يضيف/يعدّل (من الكود)
    }

  }
}
